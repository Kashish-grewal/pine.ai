# ================================================================
# Pine.AI Environment Variables — Configuration Template
# ================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# ================================================================

# ─── SERVER CONFIGURATION ──────────────────────────────────────
PORT=5001
NODE_ENV=production
LOG_LEVEL=info

# ─── DATABASE (PostgreSQL via Neon) ────────────────────────────
DATABASE_URL=postgresql://user:password@db.neon.tech/pine_db?sslmode=require
DB_POOL_SIZE=20
DB_IDLE_TIMEOUT_MS=30000

# ─── AUTHENTICATION ───────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-change-this
JWT_REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars-change
JWT_EXPIRY=24h
REFRESH_TOKEN_EXPIRY=7d

# ─── EMAIL CONFIGURATION ──────────────────────────────────────
# Option 1: Gmail SMTP (Free, good for testing)
EMAIL_PROVIDER=gmail
GMAIL_USER=your-email@gmail.com
GMAIL_PASSWORD=your-app-specific-password-16-chars

# Option 2: Resend (Production-grade, $20/month)
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Option 3: SendGrid (Enterprise)
# EMAIL_PROVIDER=sendgrid
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx

# ─── LLM SERVICES ────────────────────────────────────────────
# Groq (Transcription + LLM)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=whisper-large-v3-turbo

# Google Gemini (Fallback LLM)
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── GOOGLE OAUTH (Optional, for frontend auth) ───────────────
GOOGLE_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxx

# ─── CORS & SECURITY ──────────────────────────────────────────
ALLOWED_ORIGINS=https://pine-ai.vercel.app,http://localhost:5173,http://localhost:3000
CORS_CREDENTIALS=true

# ─── FILE UPLOAD ──────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=100
UPLOAD_DIR=./uploads/temp
ALLOWED_AUDIO_FORMATS=mp3,wav,m4a,webm,ogg,flac

# ─── RATE LIMITING ────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_MAX_LOGIN_ATTEMPTS=5

# ─── PYTHON SERVICES (Transcription) ──────────────────────────
PYTHON_EXECUTABLE=python3
WHISPER_MODEL=base
SPEAKER_EMBEDDING_MODEL=speechbrain/spk_ecapa_tdnn

# ─── MONITORING & LOGGING ─────────────────────────────────────
SENTRY_DSN=https://key@sentry.io/project
DEBUG=false
VERBOSE_LOGGING=false

# ─── FRONTEND (For reference) ──────────────────────────────────
VITE_API_BASE_URL=/api/v1
VITE_API_FALLBACK_BASE_URL=https://pine-ai-backend.onrender.com/api/v1
VITE_GOOGLE_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
